packages:
  ./*.cabal
  
constraints:
  zlib +bundled-c-zlib

  -- ghcjs does not support documentation, 
  -- because of missing dynamic linking
if(arch(javascript))
else
  package *
    documentation: true

source-repository-package
  type: git
  location: https://github.com/dmjio/miso.git
  tag: d62d4aea72b8596a8f11a6ab7e5913d8b3ca4b50
